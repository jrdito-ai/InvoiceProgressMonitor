# Copy ini ke .env.local dan isi credentials dari Supabase dashboard
# JANGAN commit .env.local ke git — add ke .gitignore

# Supabase Project URL
# Dapat dari: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Public Key
# Dapat dari: Supabase Dashboard → Settings → API → Anon public key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App name (optional)
VITE_APP_NAME=Invoice Progress Monitor
